# Server Configuration
PORT=8080

# Tunnel Authentication Key (generate via UI or set manually)
TUNNEL_AUTH_KEY=

# Domain Configuration
DOMAIN=
RAILWAY_DOMAIN=

# Connection Limits
MAX_CONNECTIONS=100

# Protocol Toggles
ENABLE_TCP=true
ENABLE_UDP=true

# Database Path (default: /app/data/tunnel.db)
DB_PATH=/app/data/tunnel.db
